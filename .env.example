# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud (REQUIRED) ──────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── OpenAI (REQUIRED — LLM + Sentiment Analysis) ─────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sarvam AI (REQUIRED — Indian-language STT + TTS) ─────────────────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (REQUIRED — Database for call logs, CRM, transcripts) ────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Supabase S3 (OPTIONAL — Call Recordings Storage) ─────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 Access → Generate key
# Create a private bucket named 'call-recordings' in Storage
SUPABASE_S3_ACCESS_KEY=your_supabase_s3_access_key_id
SUPABASE_S3_SECRET_KEY=your_supabase_s3_secret_access_key
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# ── Cal.com (OPTIONAL — Appointment Booking) ─────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CAL_EVENT_TYPE_ID=1234567

# ── Telegram Notifications (OPTIONAL) ────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── SIP / VoBiz (REQUIRED for phone calls) ───────────────────────────────────
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
OUTBOUND_TRUNK_ID=

# ── Call Transfer ─────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Anthropic (OPTIONAL — if using Claude as LLM provider) ───────────────────
ANTHROPIC_API_KEY=

# ── Google Calendar (OPTIONAL — alternative to Cal.com) ──────────────────────
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=google_creds.json

# ── Twilio WhatsApp (OPTIONAL — booking confirmations via WhatsApp) ───────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Sentry Error Tracking (OPTIONAL) ─────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production

# ── n8n Webhook (OPTIONAL — CRM/workflow integration) ────────────────────────
N8N_WEBHOOK_URL=
